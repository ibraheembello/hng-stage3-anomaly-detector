# Copy this file to _private/.env and fill in the real values.
# The compose stack reads it via `docker compose --env-file _private/.env up`.

# -- Public addressing --
EC2_PUBLIC_IP=1.2.3.4
DUCKDNS_DOMAIN=your-name.duckdns.org

# -- Slack webhook --
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# -- Database --
DB_ROOT_PASSWORD=change-me-root
DB_NAME=nextcloud
DB_USER=nextcloud
DB_PASSWORD=change-me-app

# -- Nextcloud admin --
NC_ADMIN_USER=admin
NC_ADMIN_PASSWORD=change-me-admin
